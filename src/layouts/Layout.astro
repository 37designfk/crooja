---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CROOJA',
  description = 'CROOJA - Greatest snowboard of all time',
} = Astro.props;
const b = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/jpeg" href={`${b}images/favicon.jpg`} />
    <link rel="preload" as="image" type="image/webp" imagesrcset={`${b}images/resaize__71532638-1-600.webp 600w, ${b}images/resaize__71532638-1.webp 1200w`} imagesizes="(max-width: 600px) 100vw, 33vw" />
    <title>{title === 'CROOJA' ? 'CROOJA' : `${title} | CROOJA`}</title>
    <!-- Google tag (gtag.js) - delayed load for TBT optimization -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NFTHQ4SM4Z');
      window.addEventListener('load', function() {
        setTimeout(function() {
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-NFTHQ4SM4Z';
          s.async = true;
          document.head.appendChild(s);
        }, 100);
      });
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
