---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { languages, type Lang, defaultLang } from '../i18n/config';
import { getAlternateUrls } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  pagePath?: string;
}

const {
  title = 'CROOJA',
  description = 'CROOJA - Greatest snowboard of all time',
  lang = 'ja',
  pagePath = '/',
} = Astro.props;
const b = import.meta.env.BASE_URL;

const alternateUrls = getAlternateUrls(pagePath);
const canonicalUrl = alternateUrls.find(a => a.lang === lang)?.url
  ?? `https://crooja.com${Astro.url.pathname.replace(/^\/crooja/, '')}`;
---

<!doctype html>
<html lang={languages[lang].htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {alternateUrls.map(alt => (
      <link rel="alternate" hreflang={alt.htmlLang} href={alt.url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternateUrls.find(a => a.lang === defaultLang)?.url} />
    <link rel="icon" type="image/jpeg" href={`${b}images/favicon.jpg`} />
    <link rel="preload" as="image" type="image/webp" imagesrcset={`${b}images/resaize__71532638-1-600.webp 600w, ${b}images/resaize__71532638-1.webp 1200w`} imagesizes="(max-width: 600px) 100vw, 33vw" />
    <title>{title === 'CROOJA' ? 'CROOJA' : `${title} | CROOJA`}</title>
    <!-- Google tag (gtag.js) - delayed load for TBT optimization -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NFTHQ4SM4Z');
      window.addEventListener('load', function() {
        setTimeout(function() {
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-NFTHQ4SM4Z';
          s.async = true;
          document.head.appendChild(s);
        }, 100);
      });
    </script>
  </head>
  <body>
    <Header lang={lang} pagePath={pagePath} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
