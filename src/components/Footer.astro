---

<footer class="site-footer">
  <div class="footer-inner">
    <a href="/" class="footer-logo">
      <img src="/images/crooja_logo.png" alt="CROOJA" />
    </a>
    <div class="footer-sns">
      <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="sns-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a href="https://x.com/" target="_blank" rel="noopener noreferrer" aria-label="X" class="sns-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
    </div>
    <p class="footer-copy">&copy; 2022 CROOJA. All Rights Reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: #f8f8f8;
    border-top: 1px solid #e8e8e8;
    padding: 3rem 1.5rem;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .footer-logo {
    display: inline-block;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }
  .footer-logo img {
    height: 28px;
    width: auto;
    filter: brightness(0);
    opacity: 0.6;
  }
  .footer-sns {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .sns-link {
    color: #aaa;
    text-decoration: none;
    transition: color 0.2s;
  }
  .sns-link:hover {
    color: #E69B9B;
  }
  .footer-copy {
    color: #bbb;
    font-size: 11px;
    letter-spacing: 1px;
  }
</style>
