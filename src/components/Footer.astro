---
import type { Lang } from '../i18n/config';

interface Props {
  lang?: Lang;
}

const { lang = 'ja' } = Astro.props;
const b = import.meta.env.BASE_URL;
const langPrefix = lang === 'ja' ? '' : `${lang}/`;
---

<footer class="site-footer">
  <div class="footer-inner">
    <a href={`${b}${langPrefix}`} class="footer-logo">
      <img src={`${b}images/crooja_logo.png`} alt="CROOJA" />
    </a>
    <p class="footer-copy">&copy; 2026 CROOJA. All Rights Reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: #f8f8f8;
    border-top: 1px solid #e8e8e8;
    padding: 3rem 1.5rem;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .footer-logo {
    display: inline-block;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }
  .footer-logo img {
    height: 28px;
    width: auto;
    filter: brightness(0);
    opacity: 0.6;
  }
  .footer-sns {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .sns-link {
    color: #aaa;
    text-decoration: none;
    transition: color 0.2s;
  }
  .sns-link:hover {
    color: #E69B9B;
  }
  .footer-copy {
    color: #bbb;
    font-size: 11px;
    letter-spacing: 1px;
  }
</style>
