---
import Layout from '../layouts/Layout.astro';
import { products } from '../data/products';

const newProducts = products.filter(p => p.isNew);
const b = import.meta.env.BASE_URL;
---

<Layout title="CROOJA" description="CROOJA - Greatest snowboard of all time">

  <!-- ヒーロー -->
  <section class="hero">
    <div class="hero-gallery">
      <div class="hero-img"><img src={`${b}images/resaize__71532638-1.jpg`} alt="CROOJA" /></div>
      <div class="hero-img"><img src={`${b}images/S__71532636.jpg`} alt="CROOJA" /></div>
      <div class="hero-img"><img src={`${b}images/S__71532631.jpg`} alt="CROOJA" /></div>
    </div>
    <div class="hero-overlay">
      <img src={`${b}images/crooja_logo.png`} alt="CROOJA" class="hero-logo" />
      <p class="hero-catch">Greatest snowboard of all time</p>
    </div>
  </section>

  <!-- 全ボードビジュアル (catalog-12) -->
  <section class="lineup-visual">
    <div class="lineup-label">
      <span>26-27 SEASON LINE UP</span>
    </div>
    <a href={`${b}products`}>
      <img src={`${b}images/catalog-12.png`} alt="CROOJA 26-27 LINE UP" class="lineup-img" />
    </a>
  </section>

  <!-- NEW MODEL -->
  {newProducts.length > 0 && (
    <section class="section-new">
      <div class="sec-header">
        <p class="sec-tag">26-27 NEW MODEL</p>
        <h2 class="sec-title">SPIDER</h2>
      </div>
      <div class="new-catalog-wrap">
        <a href={`${b}products/spider`}>
          <img src={`${b}images/catalog-08.png`} alt="CROOJA SPIDER catalog" class="new-catalog-img" />
        </a>
      </div>
      <div class="sec-cta">
        <a href={`${b}products/spider`} class="btn-dark">VIEW SPIDER →</a>
        <a href={`${b}products`} class="btn-outline">ALL PRODUCTS</a>
      </div>
    </section>
  )}

  <!-- NEWS -->
  <section class="section-news">
    <div class="sec-header">
      <h2 class="sec-title-sm">NEWS</h2>
    </div>
    <div class="news-table">
      <div class="news-row">
        <span class="news-tag">NEW</span>
        <span class="news-date">2022.01.25</span>
        <a href={`${b}shop`} class="news-text">取扱店舗決定!!</a>
      </div>
    </div>
  </section>

  <!-- Instagram -->
  <section class="section-insta">
    <h2 class="sec-title-sm">Instagram</h2>
    <p class="insta-hash">#crooja_snowboard</p>
    <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" class="btn-outline">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
        <circle cx="12" cy="12" r="4"/>
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
      </svg>
      @crooja_snowboard
    </a>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: #111;
  }
  .hero-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .hero-img {
    aspect-ratio: 2/3;
    overflow: hidden;
  }
  .hero-img img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top;
    display: block;
    transition: transform 10s ease;
  }
  .hero:hover .hero-img img { transform: scale(1.05); }
  .hero-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 3rem 2rem;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);
    text-align: center;
  }
  .hero-logo {
    max-width: 180px; width: 45%; height: auto; margin-bottom: 0.75rem;
  }
  .hero-catch {
    font-family: 'Cinzel', serif;
    font-size: clamp(9px, 1.5vw, 13px);
    color: rgba(255,255,255,0.8);
    letter-spacing: 4px;
  }

  /* ── Lineup visual ── */
  .lineup-visual {
    background: #fff;
    padding: 4rem 1.5rem 2rem;
    text-align: center;
  }
  .lineup-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    color: #bbb;
    letter-spacing: 5px;
    margin-bottom: 2rem;
  }
  .lineup-img {
    max-width: 900px;
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
    transition: opacity 0.3s;
  }
  .lineup-img:hover { opacity: 0.85; }

  /* ── NEW MODEL ── */
  .section-new {
    background: #f8f8f8;
    padding: 4rem 1.5rem 3rem;
    border-top: 1px solid #ebebeb;
  }
  .sec-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .sec-tag {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    color: #E69B9B;
    letter-spacing: 4px;
    margin-bottom: 0.5rem;
  }
  .sec-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 400;
    color: #111;
    letter-spacing: 10px;
  }
  .new-catalog-wrap {
    max-width: 820px;
    margin: 0 auto 2.5rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }
  .new-catalog-img {
    width: 100%; height: auto; display: block;
    transition: transform 0.4s ease;
  }
  .new-catalog-wrap:hover .new-catalog-img { transform: scale(1.01); }
  .sec-cta {
    display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;
  }
  .btn-dark {
    background: #1e1a16;
    color: #fff;
    padding: 12px 36px;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-dark:hover { background: #E69B9B; color: #fff; }
  .btn-outline {
    border: 1px solid #ccc;
    color: #555;
    padding: 12px 36px;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-decoration: none;
    display: inline-flex; align-items: center; gap: 6px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover { border-color: #E69B9B; color: #E69B9B; }

  /* ── NEWS ── */
  .section-news {
    background: #fff;
    padding: 4rem 1.5rem;
    border-top: 1px solid #ebebeb;
  }
  .sec-title-sm {
    font-family: 'Cinzel', serif;
    font-size: 18px;
    font-weight: 400;
    color: #111;
    letter-spacing: 6px;
    text-align: center;
    margin-bottom: 2rem;
  }
  .news-table {
    max-width: 680px;
    margin: 0 auto;
    border-top: 1px solid #ebebeb;
  }
  .news-row {
    display: flex; align-items: center; gap: 1.25rem;
    padding: 1rem 0;
    border-bottom: 1px solid #ebebeb;
  }
  .news-tag {
    background: #E69B9B; color: #fff;
    font-size: 9px; font-weight: 700;
    letter-spacing: 1px; padding: 2px 7px;
    font-family: 'Manrope', sans-serif;
    flex-shrink: 0;
  }
  .news-date { color: #aaa; font-size: 12px; flex-shrink: 0; }
  .news-text {
    color: #333; font-size: 13px; font-weight: 600;
    text-decoration: underline; text-underline-offset: 3px;
  }
  .news-text:hover { color: #E69B9B; }

  /* ── Instagram ── */
  .section-insta {
    background: #f8f8f8;
    padding: 4rem 1.5rem;
    text-align: center;
    border-top: 1px solid #ebebeb;
  }
  .insta-hash {
    color: #555; font-size: 14px; font-weight: 700;
    margin-bottom: 2rem;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .hero-gallery { grid-template-columns: 1fr; }
    .hero-img:not(:first-child) { display: none; }
    .hero-img { aspect-ratio: 4/3; }
    .hero-overlay { position: static; background: #111; padding: 2rem 1.5rem; }
  }
</style>
