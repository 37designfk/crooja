---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/products';
import { foreignLangs } from '../../i18n/config';
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

export function getStaticPaths() {
  return foreignLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const newProducts = products.filter(p => p.isNew);
const b = import.meta.env.BASE_URL;
const lp = `${lang}/`; // lang prefix for links
---

<Layout title="CROOJA" description={t(lang, 'site_description')} lang={lang} pagePath="/">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-gallery">
      <div class="hero-img"><picture><source srcset={`${b}images/resaize__71532638-1-600.webp 600w, ${b}images/resaize__71532638-1.webp 1200w`} sizes="(max-width: 600px) 100vw, 33vw" type="image/webp" /><img src={`${b}images/resaize__71532638-1.jpg`} alt="CROOJA" width="1200" height="900" fetchpriority="high" /></picture></div>
      <div class="hero-img"><picture><source srcset={`${b}images/S__71532636.webp`} type="image/webp" /><img src={`${b}images/S__71532636.jpg`} alt="CROOJA" width="1200" height="900" /></picture></div>
      <div class="hero-img"><picture><source srcset={`${b}images/S__71532631.webp`} type="image/webp" /><img src={`${b}images/S__71532631.jpg`} alt="CROOJA" width="1200" height="900" /></picture></div>
    </div>
    <div class="hero-overlay">
      <picture><source srcset={`${b}images/crooja_logo.webp`} type="image/webp" /><img src={`${b}images/crooja_logo.png`} alt="CROOJA" class="hero-logo" width="400" height="91" /></picture>
      <p class="hero-catch">{t(lang, 'hero_catch')}</p>
    </div>
  </section>

  <!-- Lineup visual (catalog-12) -->
  <section class="lineup-visual">
    <div class="lineup-label">
      <span>{t(lang, 'lineup_label')}</span>
    </div>
    <a href={`${b}${lp}products`}>
      <picture><source srcset={`${b}images/catalog-12.webp`} type="image/webp" /><img src={`${b}images/catalog-12.png`} alt="CROOJA 26-27 LINE UP" class="lineup-img" width="800" height="566" loading="lazy" /></picture>
    </a>
  </section>

  <!-- NEW MODEL -->
  {newProducts.length > 0 && (
    <section class="section-new">
      <div class="sec-header">
        <p class="sec-tag">{t(lang, 'new_model_tag')}</p>
        <h2 class="sec-title">SPIDER</h2>
      </div>
      <div class="new-catalog-wrap">
        <a href={`${b}${lp}products/spider`}>
          <picture><source srcset={`${b}images/catalog-08.webp`} type="image/webp" /><img src={`${b}images/catalog-08.png`} alt="CROOJA SPIDER catalog" class="new-catalog-img" width="800" height="566" loading="lazy" /></picture>
        </a>
      </div>
      <div class="sec-cta">
        <a href={`${b}${lp}products/spider`} class="btn-dark">{t(lang, 'view_spider')}</a>
        <a href={`${b}${lp}products`} class="btn-outline">{t(lang, 'all_products')}</a>
      </div>
    </section>
  )}

  <!-- Instagram -->
  <section class="section-insta">
    <h2 class="sec-title-sm">{t(lang, 'instagram_title')}</h2>
    <p class="insta-hash">{t(lang, 'instagram_hash')}</p>
    <div class="insta-embed-wrap">
      <script src="https://insta-widget.37design.co.jp/widget.js" defer></script>
      <div data-insta-widget="crooja" data-cols="3" data-rows="2"></div>
    </div>
    <div class="insta-cta">
      <a href="https://www.instagram.com/crooja_snowboard/" target="_blank" rel="noopener noreferrer" class="btn-outline">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        @crooja_snowboard
      </a>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: #111;
  }
  .hero-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .hero-img {
    aspect-ratio: 2/3;
    overflow: hidden;
  }
  .hero-img img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: top;
    display: block;
    transition: transform 10s ease;
  }
  .hero:hover .hero-img img { transform: scale(1.05); }
  .hero-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 3rem 2rem;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);
    text-align: center;
  }
  .hero-logo {
    max-width: 180px; width: 45%; height: auto; margin-bottom: 0.75rem;
  }
  .hero-catch {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: clamp(9px, 1.5vw, 13px);
    color: rgba(255,255,255,0.8);
    letter-spacing: 4px;
  }

  /* ── Lineup visual ── */
  .lineup-visual {
    background: #fff;
    padding: 4rem 1.5rem 2rem;
    text-align: center;
  }
  .lineup-label {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 10px;
    color: #bbb;
    letter-spacing: 5px;
    margin-bottom: 2rem;
  }
  .lineup-img {
    max-width: 900px;
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
    transition: opacity 0.3s;
  }
  .lineup-img:hover { opacity: 0.85; }

  /* ── NEW MODEL ── */
  .section-new {
    background: #f8f8f8;
    padding: 4rem 1.5rem 3rem;
    border-top: 1px solid #ebebeb;
  }
  .sec-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .sec-tag {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 10px;
    color: #E69B9B;
    letter-spacing: 4px;
    margin-bottom: 0.5rem;
  }
  .sec-title {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 400;
    color: #111;
    letter-spacing: 10px;
  }
  .new-catalog-wrap {
    max-width: 820px;
    margin: 0 auto 2.5rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }
  .new-catalog-img {
    width: 100%; height: auto; display: block;
    transition: transform 0.4s ease;
  }
  .new-catalog-wrap:hover .new-catalog-img { transform: scale(1.01); }
  .sec-cta {
    display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;
  }
  .btn-dark {
    background: #1e1a16;
    color: #fff;
    padding: 12px 36px;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-dark:hover { background: #E69B9B; color: #fff; }
  .btn-outline {
    border: 1px solid #ccc;
    color: #555;
    padding: 12px 36px;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-decoration: none;
    display: inline-flex; align-items: center; gap: 6px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover { border-color: #E69B9B; color: #E69B9B; }

  .sec-title-sm {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: #111;
    letter-spacing: 6px;
    text-align: center;
    margin-bottom: 2rem;
  }

  /* ── Instagram ── */
  .section-insta {
    background: #f8f8f8;
    padding: 4rem 1.5rem;
    text-align: center;
    border-top: 1px solid #ebebeb;
  }
  .insta-hash {
    color: #555; font-size: 14px; font-weight: 700;
    margin-bottom: 2rem;
  }
  .insta-embed-wrap {
    max-width: 1080px;
    margin: 0 auto 2rem;
  }
  .insta-cta {
    margin-top: 1rem;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .hero-gallery { grid-template-columns: 1fr; }
    .hero-img:not(:first-child) { display: none; }
    .hero-img { aspect-ratio: 4/3; }
    .hero-overlay { position: static; background: #111; padding: 2rem 1.5rem; }
  }
</style>
