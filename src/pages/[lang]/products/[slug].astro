---
import Layout from '../../../layouts/Layout.astro';
import { products } from '../../../data/products';
import { foreignLangs } from '../../../i18n/config';
import { t } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/config';

export function getStaticPaths() {
  return foreignLangs.flatMap(lang =>
    products.map(p => ({
      params: { lang, slug: p.slug },
      props: { product: p },
    }))
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { product } = Astro.props;
const all = products;
const idx = all.findIndex(p => p.slug === slug);
const prev = all[idx - 1] ?? null;
const next = all[idx + 1] ?? null;
const b = import.meta.env.BASE_URL;
const lp = `${lang}/`;
---

<Layout title={product.name} description={`CROOJA ${product.name} - ${product.nameJa}`} lang={lang} pagePath={`/products/${slug}`}>

  <!-- Page header -->
  <div class="prod-header">
    {product.isNew && <span class="new-badge">{t(lang, 'new_model_tag')}</span>}
    <h1 class="prod-title">{product.name}</h1>
    <p class="prod-title-ja">{product.nameJa}</p>
  </div>

  <!-- Catalog page image (main) -->
  <section class="catalog-section">
    <div class="catalog-wrap">
      <picture><source srcset={b + product.catalogImage.slice(1).replace(".png", ".webp")} type="image/webp" /><img src={b + product.catalogImage.slice(1)} alt={`CROOJA ${product.name}`} class="catalog-full" width="800" height="566" /></picture>
    </div>
  </section>

  <!-- Description -->
  <section class="desc-section">
    <div class="desc-inner">
      <p class="desc-text">{t(lang, `product_desc_${product.slug}`)}</p>
    </div>
  </section>

  <!-- Prev/Next nav -->
  <nav class="prod-nav">
    <div class="nav-inner">
      {prev ? (
        <a href={`${b}${lp}products/${prev.slug}`} class="nav-item nav-prev">
          <span class="nav-dir">{t(lang, 'product_prev')}</span>
          <span class="nav-name">{prev.name}</span>
        </a>
      ) : <div />}
      <a href={`${b}${lp}products`} class="nav-all">{t(lang, 'all_products_link')}</a>
      {next ? (
        <a href={`${b}${lp}products/${next.slug}`} class="nav-item nav-next">
          <span class="nav-dir">{t(lang, 'product_next')}</span>
          <span class="nav-name">{next.name}</span>
        </a>
      ) : <div />}
    </div>
  </nav>

</Layout>

<style>
  .prod-header {
    background: #fff;
    padding: 3.5rem 1.5rem 2rem;
    text-align: center;
    border-bottom: 1px solid #ebebeb;
  }
  .new-badge {
    display: inline-block;
    background: #E69B9B; color: #fff;
    font-size: 9px; font-weight: 700;
    letter-spacing: 3px; padding: 4px 12px;
    margin-bottom: 1rem;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .prod-title {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: clamp(32px, 6vw, 64px);
    font-weight: 400;
    color: #111;
    letter-spacing: 12px;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .prod-title-ja {
    color: #aaa;
    font-size: 13px;
    letter-spacing: 3px;
  }

  .catalog-section {
    background: #fafafa;
    padding: 3rem 1.5rem;
    border-bottom: 1px solid #ebebeb;
  }
  .catalog-wrap {
    max-width: 960px;
    margin: 0 auto;
    box-shadow: 0 2px 20px rgba(0,0,0,0.07);
    background: #fff;
  }
  .catalog-full {
    width: 100%; height: auto; display: block;
  }

  .desc-section {
    background: #fff;
    padding: 3rem 1.5rem;
    border-bottom: 1px solid #ebebeb;
  }
  .desc-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  .desc-text {
    color: #444;
    font-size: 15px;
    line-height: 2.2;
    text-align: justify;
  }

  .prod-nav {
    background: #f8f8f8;
    border-top: 1px solid #ebebeb;
    padding: 2rem 1.5rem;
  }
  .nav-inner {
    max-width: 840px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }
  .nav-item {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    transition: opacity 0.2s;
  }
  .nav-item:hover { opacity: 0.7; }
  .nav-prev { align-items: flex-start; }
  .nav-next { align-items: flex-end; }
  .nav-dir {
    color: #bbb;
    font-size: 9px;
    letter-spacing: 2px;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .nav-name {
    color: #111;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 15px;
    letter-spacing: 3px;
    font-weight: 400;
  }
  .nav-all {
    text-align: center;
    color: #999;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-all:hover { color: #E69B9B; }
</style>
