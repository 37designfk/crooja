---
import Layout from '../../layouts/Layout.astro';
import { foreignLangs } from '../../i18n/config';
import { t } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

export function getStaticPaths() {
  return foreignLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const b = import.meta.env.BASE_URL;
const lp = `${lang}/`;
---

<Layout title="CONTACT" description={`CROOJA ${t(lang, 'contact_sub')}`} lang={lang} pagePath="/contact">

  <div class="page-header">
    <h1 class="page-title">{t(lang, 'contact_title')}</h1>
    <p class="page-sub">{t(lang, 'contact_sub')}</p>
  </div>

  <section class="contact-section">
    <div class="form-wrap">
      <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="form">
        <input type="hidden" name="form-name" value="contact" />
        <input type="hidden" name="lang" value={lang} />
        <p style="display:none;"><label>Don't fill this: <input name="bot-field" /></label></p>

        <label class="field">
          <span class="field-label">{t(lang, 'form_name')} <em>*</em></span>
          <input type="text" name="name" required placeholder={t(lang, 'form_name_placeholder')} class="field-input" />
        </label>

        <label class="field">
          <span class="field-label">{t(lang, 'form_email')} <em>*</em></span>
          <input type="email" name="email" required placeholder="example@email.com" class="field-input" />
        </label>

        <label class="field">
          <span class="field-label">{t(lang, 'form_subject')} <em>*</em></span>
          <input type="text" name="subject" required placeholder={t(lang, 'form_subject_placeholder')} class="field-input" />
        </label>

        <label class="field">
          <span class="field-label">{t(lang, 'form_message')} <em>*</em></span>
          <textarea name="message" required rows="7" placeholder={t(lang, 'form_message_placeholder')} class="field-input field-textarea"></textarea>
        </label>

        <button type="submit" class="submit-btn">{t(lang, 'form_send')}</button>
      </form>

      <p class="note">
        {t(lang, 'form_note_1')}<br />
        {t(lang, 'form_note_2')}
      </p>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    background: #fff;
    padding: 4rem 1.5rem 2rem;
    text-align: center;
    border-bottom: 1px solid #ebebeb;
  }
  .page-title {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 400;
    color: #111;
    letter-spacing: 14px;
    margin-bottom: 0.5rem;
  }
  .page-sub {
    color: #bbb;
    font-size: 11px;
    letter-spacing: 4px;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .contact-section {
    background: #fff;
    padding: 3rem 1.5rem 5rem;
  }
  .form-wrap {
    max-width: 600px;
    margin: 0 auto;
  }
  .form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field-label {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 10px;
    color: #888;
    letter-spacing: 2px;
  }
  .field-label em {
    color: #E69B9B;
    font-style: normal;
    margin-left: 3px;
  }
  .field-input {
    background: #fff;
    border: 1px solid #ddd;
    color: #111;
    padding: 11px 14px;
    font-size: 14px;
    width: 100%;
    border-radius: 2px;
    outline: none;
    transition: border-color 0.2s;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .field-input:focus {
    border-color: #E69B9B;
  }
  .field-textarea {
    resize: vertical;
  }
  .submit-btn {
    background: #1e1a16;
    color: #fff;
    border: none;
    padding: 13px 48px;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 12px;
    letter-spacing: 4px;
    cursor: pointer;
    transition: background 0.2s;
    align-self: flex-start;
  }
  .submit-btn:hover {
    background: #E69B9B;
  }
  .note {
    color: #bbb;
    font-size: 12px;
    margin-top: 2rem;
    line-height: 2;
  }
</style>
