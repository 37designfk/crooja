---
import Layout from '../layouts/Layout.astro';

const shops = [
  { name: 'スポタカ',        url: 'https://spotaka.co.jp/',             desc: '心斎橋BIGSTEP本店', area: '大阪' },
  { name: 'SPORTS BOMBER',  url: 'https://instagram.com/sports_bomber', desc: 'SPORTS BOMBER', area: '' },
  { name: 'BREAK OUT',      url: 'https://www.breakout-jp.com/',        desc: 'BREAK OUT', area: '' },
  { name: 'FLEA BOARDSHOP', url: 'https://flea.jp/',                    desc: '熊谷店 / 高崎 / 伊勢崎 / WEB', area: '関東' },
  { name: 'MISTY',          url: 'https://www.misty-snow.com/',         desc: 'MISTY', area: '' },
  { name: 'DREAMY',         url: 'https://www.dreamy1117.com/',         desc: 'DREAMY', area: '' },
  { name: 'APORITO',        url: 'https://dot9.biz/',                   desc: '広島店 / 豊橋', area: '中国・東海' },
  { name: 'DOT9',           url: 'https://dot9.biz/',                   desc: 'DOT9', area: '' },
  { name: 'ウインドボーイ',   url: 'https://www.windboy.jp/',             desc: 'ウインドボーイ', area: '' },
  { name: 'SHIFT',          url: '#',                                   desc: 'SHIFT', area: '' },
  { name: 'FEELS',          url: '#',                                   desc: 'FEELS', area: '' },
];
---

<Layout title="SHOP" description="CROOJA 取扱店舗一覧 26-27">

  <section class="hero">
    <div class="hero-inner">
      <p class="hero-label">AUTHORIZED DEALERS</p>
      <h1 class="hero-title">SHOP</h1>
      <div class="hero-line"></div>
      <p class="hero-sub">取扱店舗</p>
    </div>
  </section>

  <section class="shop-section">
    <div class="shop-list">
      {shops.map((shop, i) => (
        <a href={shop.url} target="_blank" rel="noopener noreferrer" class="shop-card" style={`--delay: ${i * 0.05}s`}>
          <div class="shop-info">
            <div class="shop-number">{String(i + 1).padStart(2, '0')}</div>
            <div>
              <h3 class="shop-name">{shop.name}</h3>
              <p class="shop-desc">{shop.desc}</p>
            </div>
          </div>
          <div class="shop-right">
            {shop.area && <span class="shop-area">{shop.area}</span>}
            <svg class="shop-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="cta-section">
    <p class="cta-text">取扱店舗のお問い合わせ・新規お取引のご相談</p>
    <a href={`${import.meta.env.BASE_URL}contact`} class="cta-btn">CONTACT</a>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    background: #fff;
    padding: 6rem 1.5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(230,155,155,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
  }
  .hero-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 6px;
    color: #bbb;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .hero-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(36px, 8vw, 64px);
    font-weight: 400;
    color: #111;
    letter-spacing: 16px;
    margin-bottom: 1.5rem;
  }
  .hero-line {
    width: 40px;
    height: 1px;
    background: #E69B9B;
    margin: 0 auto 1rem;
  }
  .hero-sub {
    color: #aaa;
    font-size: 12px;
    letter-spacing: 4px;
  }

  /* Shop List */
  .shop-section {
    background: #fff;
    padding: 0 1.5rem 4rem;
  }
  .shop-list {
    max-width: 800px;
    margin: 0 auto;
  }
  .shop-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.4rem 1.2rem;
    border-bottom: 1px solid #ebebeb;
    text-decoration: none;
    color: #111;
    transition: background 0.3s, border-color 0.3s;
    animation: fadeUp 0.5s ease both;
    animation-delay: var(--delay);
  }
  .shop-card:hover {
    background: #fafafa;
    border-color: #ddd;
  }
  .shop-card:first-child {
    border-top: 1px solid #ebebeb;
  }

  .shop-info {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  .shop-number {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    color: #ccc;
    letter-spacing: 2px;
    min-width: 24px;
  }
  .shop-name {
    font-size: 17px;
    font-weight: 600;
    color: #222;
    margin-bottom: 0.2rem;
    letter-spacing: 0.5px;
    transition: color 0.3s;
  }
  .shop-card:hover .shop-name {
    color: #E69B9B;
  }
  .shop-desc {
    color: #aaa;
    font-size: 11px;
    letter-spacing: 0.5px;
  }

  .shop-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }
  .shop-area {
    font-size: 10px;
    color: #999;
    letter-spacing: 2px;
    border: 1px solid #ddd;
    padding: 3px 10px;
    border-radius: 2px;
  }
  .shop-arrow {
    color: #ccc;
    transition: color 0.3s, transform 0.3s;
  }
  .shop-card:hover .shop-arrow {
    color: #E69B9B;
    transform: translate(2px, -2px);
  }

  /* CTA */
  .cta-section {
    background: #fafafa;
    text-align: center;
    padding: 3rem 1.5rem 5rem;
    border-top: 1px solid #ebebeb;
  }
  .cta-text {
    color: #888;
    font-size: 13px;
    margin-bottom: 1.5rem;
    letter-spacing: 1px;
  }
  .cta-btn {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 4px;
    color: #E69B9B;
    border: 1px solid #E69B9B;
    padding: 12px 40px;
    text-decoration: none;
    transition: background 0.3s, color 0.3s;
  }
  .cta-btn:hover {
    background: #E69B9B;
    color: #fff;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 600px) {
    .shop-card {
      padding: 1.2rem 0.8rem;
    }
    .shop-area {
      display: none;
    }
    .shop-number {
      display: none;
    }
  }
</style>
